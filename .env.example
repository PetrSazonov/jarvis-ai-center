# ----------------------------
# Required
# ----------------------------
BOT_TOKEN=replace_with_your_telegram_bot_token

# ----------------------------
# Ollama / LLM
# ----------------------------
OLLAMA_API_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=gemma3:27b
OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_SOFT_TIMEOUT_SECONDS=25
SYSTEM_PROMPT=You are a local AI companion. Keep responses practical, concise, and helpful.

# ----------------------------
# Market / weather / data
# ----------------------------
COINGECKO_VS=usd
PRICE_CURRENCIES=usd,eur,rub
CRYPTO_POLL_SECONDS=600
CRYPTO_ALERT_PCT=2.0
WEATHER_CITY=Moscow
FUEL95_SOURCE_URL=https://www.petrolplus.ru/fuelindex/gorod-moskva/ai95/
FUEL95_MOSCOW_RUB=

# ----------------------------
# Personal context
# ----------------------------
HOME_ADDRESS=
WORK_ADDRESS=
BIRTH_DATE=15.12.1984
MOTO_SEASON_START=04-15

# ----------------------------
# Runtime / app behavior
# ----------------------------
DEFAULT_LANG=ru
LOG_LEVEL=INFO
TIMEZONE=
MAX_HISTORY_MESSAGES=24
DATABASE_NAME=jarvis.db
STYLE_MODE=neutral
FEEDBACK_MIN_CHARS=280

# ----------------------------
# Background workers
# ----------------------------
ENABLE_CRYPTO_WATCHER=false
ENABLE_AUTO_DIGEST=true
DIGEST_CHAT_ID=
DIGEST_TIMES=07:00,14:00,21:00
ENABLE_PREWARM=true
PREWARM_INTERVAL_SECONDS=600

# ----------------------------
# Optional LLM text enhancer
# ----------------------------
ENABLE_LLM_ENHANCER=false
LLM_ENHANCER_TIMEOUT_SECONDS=3.5

# ----------------------------
# Optional Fitness Vault (private channel)
# ----------------------------
FITNESS_VAULT_CHAT_ID=
FITNESS_ADMIN_USER_ID=
FITNESS_LOG_CHAT_ID=
