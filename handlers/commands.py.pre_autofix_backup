    @router.message(F.location)
    async def route_eta_from_location(message: types.Message) -> None:
        user_id = message.from_user.id if message.from_user else 0
        target = route_eta_pending.pop(user_id, None)
        if target is None:
            return

        location = message.location
        if not location:
            await message.reply(t(ctx.settings.default_lang, "route_eta_failed"), reply_markup=ReplyKeyboardRemove())
            return

        dest = HOME_COORDS if target == "home" else WORK_COORDS
        try:
            minutes = await _estimate_drive_eta_minutes(
                origin_lat=float(location.latitude),
                origin_lon=float(location.longitude),
                dest_lat=dest[0],
                dest_lon=dest[1],
            )
        except ExternalAPIError as exc:
            rid = _request_id()
            uid = message.from_user.id if message.from_user else 0
            ctx.logger.warning(
                "event=api_error request_id=%s user_id=%s service=%s kind=%s status=%s",
                rid,
                uid,
                exc.service,
                exc.kind,
                exc.status_code,
            )
