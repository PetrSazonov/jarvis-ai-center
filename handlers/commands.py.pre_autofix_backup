    @router.callback_query(F.data.startswith("subs:"))
    async def subs_callback(callback: CallbackQuery) -> None:
        raw = callback.data or ""
        parts = raw.split(":")
        lang = ctx.settings.default_lang
        user_id = callback.from_user.id if callback.from_user else 0
        if len(parts) != 3 or user_id <= 0:
            await callback.answer(t(lang, "digest_bad_format"), show_alert=False)
            return
        _, action, value = parts

        if action == "menu":
            if callback.message:
                await callback.message.edit_text(t(lang, "subs_menu"), reply_markup=_subs_menu_markup(), parse_mode="HTML")
            await callback.answer(t(lang, "done_short"), show_alert=False)
            return

        if action == "add":
            subs_add_mode.add(user_id)
            if callback.message:
                await callback.message.reply(t(lang, "subs_add_prompt"))
            await callback.answer(t(lang, "done_short"), show_alert=False)
            return

        if action in {"list", "check"}:
            rows = subs_list(user_id=user_id)
            if not rows:
                if callback.message:
                    await callback.message.edit_text(t(lang, "subs_empty"), reply_markup=_subs_menu_markup())
                await callback.answer(t(lang, "done_short"), show_alert=False)
                return
            title = t(lang, "subs_list_title") if action == "list" else t(lang, "subs_check_title")
            lines = [t(lang, "screen_subs_title"), "", title]
            for sub_id, name, next_date, period in rows:
                lines.append(_subs_line(int(sub_id), str(name), str(next_date), str(period), lang))
            if callback.message:
                await callback.message.edit_text("\n".join(lines), reply_markup=_subs_list_markup(rows))
            await callback.answer(t(lang, "done_short"), show_alert=False)
            return

        if action == "roll" and value.isdigit():
            sub_id = int(value)
            row = subs_get(user_id=user_id, sub_id=sub_id)
            if not row:
                await callback.answer(t(lang, "subs_not_found"), show_alert=False)
                return
            _sid, _name, next_date_iso, period = row
            try:
                next_dt = date.fromisoformat(str(next_date_iso))
            except ValueError:
                await callback.answer(t(lang, "subs_bad_date"), show_alert=False)
                return
            next_dt = _roll_date(next_dt, str(period), 1)
            subs_update_next_date(
                user_id=user_id,
                sub_id=sub_id,
                next_date=next_dt.isoformat(),
                updated_at=datetime.now().isoformat(timespec="seconds"),
            )
            rows = subs_list(user_id=user_id)
            lines = [t(lang, "screen_subs_title"), "", t(lang, "subs_check_title")]
            for sid, name, next_date, per in rows:
                lines.append(_subs_line(int(sid), str(name), str(next_date), str(per), lang))
            if callback.message:
                await callback.message.edit_text("\n".join(lines), reply_markup=_subs_list_markup(rows))
            await callback.answer(t(lang, "subs_rolled", sub_id=sub_id, date=next_dt.isoformat()), show_alert=False)
            return

        if action == "del" and value.isdigit():
            sub_id = int(value)
            ok = subs_delete(user_id=user_id, sub_id=sub_id)
            rows = subs_list(user_id=user_id)
            if not rows:
                if callback.message:
                    await callback.message.edit_text(t(lang, "subs_empty"), reply_markup=_subs_menu_markup())
                await callback.answer(t(lang, "subs_deleted", sub_id=sub_id) if ok else t(lang, "subs_not_found"), show_alert=False)
                return
            lines = [t(lang, "screen_subs_title"), "", t(lang, "subs_list_title")]
            for sid, name, next_date, per in rows:
                lines.append(_subs_line(int(sid), str(name), str(next_date), str(per), lang))
            if callback.message:
                await callback.message.edit_text("\n".join(lines), reply_markup=_subs_list_markup(rows))
            await callback.answer(t(lang, "subs_deleted", sub_id=sub_id) if ok else t(lang, "subs_not_found"), show_alert=False)
            return

        await callback.answer(t(lang, "digest_unknown_action"), show_alert=False)

    @router.message(lambda m: bool(m.from_user and m.from_user.id in subs_add_mode and m.text and not m.text.startswith("/")))
    async def subs_add_from_text(message: types.Message) -> None:
        user_id = message.from_user.id if message.from_user else 0
        lang = ctx.settings.default_lang
        text = (message.text or "").strip()
        if user_id <= 0:
            return
        subs_add_mode.discard(user_id)
        parts = [p.strip() for p in text.split("|")]
        if len(parts) != 3:
            await message.reply(t(lang, "subs_help"))
            return
        name, date_part, period_part = parts
        if not name:
            await message.reply(t(lang, "subs_help"))
            return
        try:
            date.fromisoformat(date_part)
        except ValueError:
            await message.reply(t(lang, "subs_bad_date"))
            return
        period = _subs_period_normalize(period_part)
        if not period:
            await message.reply(t(lang, "subs_bad_period"))
            return
        sub_id = subs_add(
            user_id=user_id,
            name=name,
            next_date=date_part,
            period=period,
            created_at=datetime.now().isoformat(timespec="seconds"),
        )
        rows = subs_list(user_id=user_id)
        lines = [t(lang, "screen_subs_title"), "", t(lang, "subs_list_title")]
        for sid, n, next_date, per in rows:
            lines.append(_subs_line(int(sid), str(n), str(next_date), str(per), lang))
        await message.reply(t(lang, "subs_added", sub_id=sub_id))
        await message.reply("\n".join(lines), reply_markup=_subs_list_markup(rows))

    @router.message(Command("clean"))
    async def clean_chat(message: types.Message) -> None:
        user_id = message.from_user.id if message.from_user else 0
        chat_id = message.chat.id if message.chat else 0
        lang = ctx.settings.default_lang
        if user_id <= 0 or chat_id == 0:
            await message.reply(t(lang, "error_generic"))
            return

        save_conversation_history(user_id, [])
        clean_pending.add(user_id)

        current_mid = int(message.message_id or 0)
        deleted = 0
        fail_streak = 0
        scanned = 0
        lower_bound = max(0, current_mid - CLEAN_SCAN_LIMIT)
        # Best effort cleanup in private chat. Telegram may deny some deletions for old/system messages.
        try:
            for mid in range(current_mid, lower_bound, -1):
                scanned += 1
                try:
                    await ctx.bot.delete_message(chat_id=chat_id, message_id=mid)
                    deleted += 1
                    fail_streak = 0
                except Exception as exc:
                    retry_after = getattr(exc, "retry_after", None)
                    if retry_after:
                        try:
                            await asyncio.sleep(float(retry_after))
                        except (TypeError, ValueError):
                            await asyncio.sleep(0.5)
                    fail_streak += 1
                    if deleted > 0 and fail_streak >= CLEAN_FAIL_STREAK_STOP:
                        break
                if scanned % CLEAN_PAUSE_EVERY == 0:
                    await asyncio.sleep(CLEAN_PAUSE_SECONDS)
        finally:
            clean_pending.discard(user_id)

        if deleted == 0:
            await message.reply(t(lang, "clean_result_none"))
            return

        # Self-destructing confirmation so chat stays visually clean.
        confirm = await message.answer(t(lang, "clean_result", count=deleted))
        try:
            await asyncio.sleep(1.0)
            await ctx.bot.delete_message(chat_id=chat_id, message_id=confirm.message_id)
        except Exception:
            pass

    @router.message(Command("todo"))
    async def todo_command(message: types.Message) -> None:
        text = (message.text or "").strip()
        parts = text.split(maxsplit=2)
        user_id = message.from_user.id if message.from_user else 0
        if user_id <= 0:
            await message.reply(t(ctx.settings.default_lang, "error_generic"))
            return

        if len(parts) == 1:
            rows = todo_list_open(user_id=user_id, limit=12)
            await message.reply(_todo_text(ctx.settings.default_lang, rows), reply_markup=_todo_markup(rows))
            return

        action = parts[1].lower()
        if action == "add":
            if len(parts) < 3 or not parts[2].strip():
                await message.reply(t(ctx.settings.default_lang, "todo_bad_format"))
                return
            todo_id = todo_add(
                user_id=user_id,
                text=parts[2].strip(),
                created_at=datetime.now().isoformat(timespec="seconds"),
            )
            await message.reply(t(ctx.settings.default_lang, "todo_added", todo_id=todo_id))
            return

        if action == "list":
            rows = todo_list_open(user_id=user_id, limit=20)
            await message.reply(_todo_text(ctx.settings.default_lang, rows), reply_markup=_todo_markup(rows))
            return

        if action in {"done", "del"}:
            if len(parts) < 3 or not parts[2].strip().isdigit():
                await message.reply(t(ctx.settings.default_lang, "todo_bad_format"))
                return
            todo_id = int(parts[2].strip())
            if action == "done":
                ok = todo_mark_done(user_id=user_id, todo_id=todo_id, done_at=datetime.now().isoformat(timespec="seconds"))
                await message.reply(
                    t(ctx.settings.default_lang, "todo_done", todo_id=todo_id)
                    if ok
                    else t(ctx.settings.default_lang, "todo_not_found")
                )
                return
            ok = todo_delete(user_id=user_id, todo_id=todo_id)
            await message.reply(
                t(ctx.settings.default_lang, "todo_deleted", todo_id=todo_id)
                if ok
                else t(ctx.settings.default_lang, "todo_not_found")
            )
            return

        await message.reply(t(ctx.settings.default_lang, "todo_bad_format"))

    @router.callback_query(F.data.startswith("todo:"))
    async def todo_callback(callback: CallbackQuery) -> None:
        raw = callback.data or ""
        parts = raw.split(":")
        if len(parts) != 3:
            await callback.answer(t(ctx.settings.default_lang, "digest_bad_format"), show_alert=False)
            return
        _, action, arg = parts
        user_id = callback.from_user.id if callback.from_user else 0
        lang = ctx.settings.default_lang
        if user_id <= 0:
            await callback.answer(t(lang, "error_generic"), show_alert=False)
            return

        if action == "add":
            todo_add_mode.add(user_id)
            if callback.message:
                await callback.message.reply(t(lang, "todo_add_prompt"))
            await callback.answer(t(lang, "done_short"), show_alert=False)
            return

        if action == "list":
            rows = todo_list_open(user_id=user_id, limit=20)
            text = _todo_text(lang, rows)
            await _safe_edit_todo_message(callback, text=text, rows=rows)
            await callback.answer(t(lang, "done_short"), show_alert=False)
            return

        if action in {"done", "del"} and arg.isdigit():
            todo_id = int(arg)
            if action == "done":
                ok = todo_mark_done(user_id=user_id, todo_id=todo_id, done_at=datetime.now().isoformat(timespec="seconds"))
                answer = t(lang, "todo_done", todo_id=todo_id) if ok else t(lang, "todo_not_found")
            else:
                ok = todo_delete(user_id=user_id, todo_id=todo_id)
                answer = t(lang, "todo_deleted", todo_id=todo_id) if ok else t(lang, "todo_not_found")

            rows = todo_list_open(user_id=user_id, limit=20)
            text = _todo_text(lang, rows)
            await _safe_edit_todo_message(callback, text=text, rows=rows)
            await callback.answer(answer, show_alert=False)
            return

        await callback.answer(t(lang, "todo_bad_format"), show_alert=False)

    @router.message(lambda m: bool(m.from_user and m.from_user.id in todo_add_mode and m.text and not m.text.startswith("/")))
    async def todo_add_from_text(message: types.Message) -> None:
        user_id = message.from_user.id if message.from_user else 0
        lang = ctx.settings.default_lang
        text = (message.text or "").strip()
        if user_id <= 0:
            return
        todo_add_mode.discard(user_id)
        if not text:
            await message.reply(t(lang, "todo_bad_format"))
            return
        todo_id = todo_add(user_id=user_id, text=text, created_at=datetime.now().isoformat(timespec="seconds"))
        rows = todo_list_open(user_id=user_id, limit=20)
        await message.reply(
            f"{t(lang, 'todo_added', todo_id=todo_id)}\n\n{_todo_text(lang, rows)}",
            reply_markup=_todo_markup(rows),
        )

    async def _cancel_startnow(user_id: int) -> None:
        task = startnow_tasks.pop(user_id, None)
        if task:
            task.cancel()
            try:
                await task
            except asyncio.CancelledError:
                pass

