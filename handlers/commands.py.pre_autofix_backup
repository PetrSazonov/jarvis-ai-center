    @router.callback_query(F.data.startswith("llmset:"))
    async def llmset_callback(callback: CallbackQuery) -> None:
        raw = callback.data or ""
        parts = raw.split(":")
        lang = ctx.settings.default_lang
        user_id = callback.from_user.id if callback.from_user else 0
        if user_id <= 0 or len(parts) != 3:
            await callback.answer(t(lang, "error_generic"), show_alert=False)
            return

        _, action, value = parts
        now = datetime.now().isoformat(timespec="seconds")
        if action == "mode" and value in {"fast", "normal", "precise"}:
            user_settings_set_mode(user_id=user_id, mode=value, updated_at=now)
            if callback.message:
                await callback.message.edit_text(
                    t(lang, "mode_set", mode=value),
                    reply_markup=_mode_markup(value),
                )
            await callback.answer(t(lang, "done_short"), show_alert=False)
            return

        if action == "conf" and value in {"on", "off"}:
            enabled = value == "on"
            user_settings_set_confidence(
                user_id=user_id,
                show_confidence=enabled,
                updated_at=now,
            )
            if callback.message:
                await callback.message.edit_text(
                    t(lang, "confidence_set", state=value),
                    reply_markup=_confidence_markup(enabled),
                )
            await callback.answer(t(lang, "done_short"), show_alert=False)
            return

        await callback.answer(t(lang, "digest_unknown_action"), show_alert=False)

