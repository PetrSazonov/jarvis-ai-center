    @router.callback_query(F.data.startswith("settings:"))
    async def settings_callback(callback: CallbackQuery) -> None:
        raw = callback.data or ""
        parts = raw.split(":")
        user_id = callback.from_user.id if callback.from_user else 0
        if user_id <= 0 or len(parts) < 3:
            await callback.answer(t(ctx.settings.default_lang, "error_generic"), show_alert=False)
            return
        _, action, value = parts[0], parts[1], parts[2]
        now_iso = datetime.now().isoformat(timespec="seconds")
        runtime_settings, profile, lang = _resolve_user_runtime_settings(ctx, user_id)

        if action == "lang":
            current = str(profile.get("lang") or runtime_settings.default_lang)
            user_settings_set_lang(
                user_id=user_id,
                lang=("en" if current == "ru" else "ru"),
                updated_at=now_iso,
            )
        elif action == "mode":
            next_mode = _cycle_value(str(profile.get("llm_mode") or "normal"), ["fast", "normal", "precise"])
            user_settings_set_mode(user_id=user_id, mode=next_mode, updated_at=now_iso)
        elif action == "digest":
            curr = str(profile.get("digest_format") or "compact")
            user_settings_set_digest_format(
                user_id=user_id,
                digest_format=("expanded" if curr == "compact" else "compact"),
                updated_at=now_iso,
            )
        elif action == "quiet":
            qs = str(profile.get("quiet_start") or "")
            qe = str(profile.get("quiet_end") or "")
            if qs and qe:
                user_settings_set_quiet_hours(
                    user_id=user_id,
                    quiet_start=None,
                    quiet_end=None,
                    updated_at=now_iso,
                )
            else:
                user_settings_set_quiet_hours(
                    user_id=user_id,
                    quiet_start="23:00",
                    quiet_end="07:00",
                    updated_at=now_iso,
                )
        elif action == "tz":
            current = profile.get("timezone_name") or None
            next_tz = _cycle_value(str(current or "system"), ["system", "Europe/Moscow", "UTC"])
            user_settings_set_timezone(
                user_id=user_id,
                timezone_name=None if next_tz == "system" else next_tz,
                updated_at=now_iso,
            )
        elif action == "city":
            settings_city_mode.add(user_id)
