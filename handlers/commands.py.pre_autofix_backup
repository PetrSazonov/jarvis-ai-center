    @router.callback_query(F.data.startswith("today:"))
    async def today_callback(callback: CallbackQuery) -> None:
        raw = callback.data or ""
        parts = raw.split(":")
        user_id = callback.from_user.id if callback.from_user else 0
        runtime_settings, profile, lang = _resolve_user_runtime_settings(ctx, user_id)
        if len(parts) != 3 or user_id <= 0:
            await callback.answer(t(lang, "digest_bad_format"), show_alert=False)
            return
        _, action, value = parts
        if action == "done" and value.isdigit():
            todo_id = int(value)
            todo_mark_done(user_id=user_id, todo_id=todo_id, done_at=datetime.now().isoformat(timespec="seconds"))
        text, markup = await _build_today_payload(
            ctx,
            user_id,
            lang,
            runtime_settings=runtime_settings,
            profile=profile,
        )
        text = await _maybe_enhance_today_text(ctx, user_id=user_id, text=text)
        if callback.message:
            try:
                await callback.message.edit_text(text, reply_markup=markup)
            except Exception:
                await callback.message.reply(text, reply_markup=markup)
        await callback.answer(t(lang, "done_short"), show_alert=False)

    @router.message(Command("checkin"))
    async def checkin_command(message: types.Message) -> None:
        text = (message.text or "").strip()
        user_id = message.from_user.id if message.from_user else 0
        lang = ctx.settings.default_lang
        if user_id <= 0:
            await message.reply(t(lang, "error_generic"))
            return

        parts = text.split(maxsplit=1)
        if len(parts) == 1:
            await message.reply(t(lang, "checkin_help"))
            return

        payload = parts[1].strip()
        if payload.lower() == "show":
            row = daily_checkin_get(user_id=user_id, check_date=date.today().isoformat())
            if not row:
                await message.reply(t(lang, "checkin_empty"))
                return
            done_text = str(row[0] or "").strip() or "-"
            carry_text = str(row[1] or "").strip() or "-"
            energy = row[2] if row[2] is not None else "-"
            await message.reply(
                t(
                    lang,
                    "checkin_show",
                    date=date.today().isoformat(),
                    done=done_text,
                    carry=carry_text,
                    energy=energy,
                )
            )
            return

        data: dict[str, str] = {}
        for item in payload.split(";"):
            chunk = item.strip()
            if not chunk or "=" not in chunk:
                continue
            key, value = chunk.split("=", 1)
            data[key.strip().lower()] = value.strip()

        done_text = data.get("done", "")
        carry_text = data.get("carry", "")
        energy_raw = data.get("energy")
        energy_val: int | None = None
        if energy_raw:
            if not energy_raw.isdigit():
                await message.reply(t(lang, "checkin_bad_format"))
                return
            energy_val = int(energy_raw)
            if energy_val < 1 or energy_val > 10:
                await message.reply(t(lang, "checkin_bad_format"))
                return

        if not done_text and not carry_text and energy_val is None:
            await message.reply(t(lang, "checkin_help"))
            return

        now_iso = datetime.now().isoformat(timespec="seconds")
        daily_checkin_upsert(
            user_id=user_id,
            check_date=date.today().isoformat(),
            done_text=done_text,
            carry_text=carry_text,
            energy=energy_val,
            created_at=now_iso,
            updated_at=now_iso,
        )
        await message.reply(t(lang, "checkin_saved"))

