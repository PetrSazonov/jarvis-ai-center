def _cache_age_minutes(updated_at: str | None) -> int | None:
    if not updated_at:
        return None
    try:
        dt = datetime.fromisoformat(updated_at)
        return max(1, int((datetime.now() - dt).total_seconds() // 60))
    except ValueError:
        return None


def _is_cache_fresh(updated_at: str | None) -> bool:
    age = _cache_age_minutes(updated_at)
    return age is None or age <= CACHE_MAX_AGE_MINUTES


def _is_cache_fast_usable(updated_at: str | None) -> bool:
    age = _cache_age_minutes(updated_at)
    return age is not None and age <= CACHE_FAST_MAX_AGE_MINUTES


def _cache_status_note(lang: str, updated_at: str | None) -> str:
    age = _cache_age_minutes(updated_at)
    if age is None:
        return t(lang, "status_cache_empty")
    if _is_cache_fresh(updated_at):
        return t(lang, "status_cache_fresh", minutes=age)
    return t(lang, "status_cache_stale", minutes=age)


def _latest_cache_timestamp(*keys: str) -> str | None:
    latest: str | None = None
    for key in keys:
        row = get_cache_value(key)
        ts = str(row[1]) if row and len(row) > 1 and row[1] else None
        if ts and (latest is None or ts > latest):
            latest = ts
    return latest


