    @router.message(Command("subs"))
    async def subs_command(message: types.Message) -> None:
        lang = ctx.settings.default_lang
        user_id = message.from_user.id if message.from_user else 0
        if user_id <= 0:
            await message.reply(t(lang, "error_generic"))
            return

        text = (message.text or "").strip()
        parts = text.split()
        if len(parts) == 1:
            await message.reply(t(lang, "subs_menu"), reply_markup=_subs_menu_markup(), parse_mode="HTML")
            return

        action = parts[1].lower()
        if action == "add":
            if len(parts) < 5:
                await message.reply(t(lang, "subs_help"))
                return
            date_part = parts[-2]
            period_part = parts[-1]
            name = " ".join(parts[2:-2]).strip()
            if not name:
                await message.reply(t(lang, "subs_help"))
                return
            try:
                date.fromisoformat(date_part)
            except ValueError:
                await message.reply(t(lang, "subs_bad_date"))
                return
            period = _subs_period_normalize(period_part)
            if not period:
                await message.reply(t(lang, "subs_bad_period"))
                return
            sub_id = subs_add(
                user_id=user_id,
                name=name,
                next_date=date_part,
                period=period,
                created_at=datetime.now().isoformat(timespec="seconds"),
            )
            await message.reply(t(lang, "subs_added", sub_id=sub_id))
            return

        if action == "list":
            rows = subs_list(user_id=user_id)
            if not rows:
                await message.reply(t(lang, "subs_empty"))
                return
            lines = [t(lang, "screen_subs_title"), "", t(lang, "subs_list_title")]
            for sub_id, name, next_date, period in rows:
                lines.append(_subs_line(int(sub_id), str(name), str(next_date), str(period), lang))
            await message.reply("\n".join(lines), reply_markup=_subs_list_markup(rows))
            return

        if action == "check":
            rows = subs_list(user_id=user_id)
            if not rows:
                await message.reply(t(lang, "subs_empty"))
                return
            lines = [t(lang, "screen_subs_title"), "", t(lang, "subs_check_title")]
            for sub_id, name, next_date, period in rows:
                lines.append(_subs_line(int(sub_id), str(name), str(next_date), str(period), lang))
            await message.reply("\n".join(lines), reply_markup=_subs_list_markup(rows))
            return

        if action == "roll":
            if len(parts) < 3 or not parts[2].isdigit():
                await message.reply(t(lang, "subs_help"))
                return
            sub_id = int(parts[2])
            count = 1
            if len(parts) >= 4 and parts[3].isdigit():
                count = int(parts[3])
            row = subs_get(user_id=user_id, sub_id=sub_id)
            if not row:
                await message.reply(t(lang, "subs_not_found"))
                return
            _sid, name, next_date_iso, period = row
            try:
                next_dt = date.fromisoformat(str(next_date_iso))
            except ValueError:
                await message.reply(t(lang, "subs_bad_date"))
                return
            next_dt = _roll_date(next_dt, str(period), count)
            ok = subs_update_next_date(
                user_id=user_id,
                sub_id=sub_id,
                next_date=next_dt.isoformat(),
                updated_at=datetime.now().isoformat(timespec="seconds"),
            )
            await message.reply(t(lang, "subs_rolled", sub_id=sub_id, date=next_dt.isoformat()) if ok else t(lang, "subs_not_found"))
            return

        if action == "del":
            if len(parts) < 3 or not parts[2].isdigit():
                await message.reply(t(lang, "subs_help"))
                return
            sub_id = int(parts[2])
            ok = subs_delete(user_id=user_id, sub_id=sub_id)
            await message.reply(t(lang, "subs_deleted", sub_id=sub_id) if ok else t(lang, "subs_not_found"))
            return

        await message.reply(t(lang, "subs_help"))

