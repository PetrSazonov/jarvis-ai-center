def _subs_period_normalize(value: str) -> str | None:
    raw = (value or "").strip().lower()
    mapping = {
        "monthly": "monthly",
        "month": "monthly",
        "m": "monthly",
        "weekly": "weekly",
        "week": "weekly",
        "w": "weekly",
        "yearly": "yearly",
        "year": "yearly",
        "y": "yearly",
        "quarterly": "quarterly",
        "quarter": "quarterly",
        "q": "quarterly",
    }
    return mapping.get(raw)


def _add_months(value: date, months: int) -> date:
    month = value.month - 1 + months
    year = value.year + month // 12
    month = month % 12 + 1
    day = min(value.day, [31, 29 if year % 4 == 0 and (year % 100 != 0 or year % 400 == 0) else 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31][month - 1])
    return date(year, month, day)


def _roll_date(next_date: date, period: str, count: int) -> date:
    steps = max(1, count)
    if period == "weekly":
        return next_date + timedelta(days=7 * steps)
    if period == "monthly":
        return _add_months(next_date, steps)
    if period == "quarterly":
        return _add_months(next_date, steps * 3)
    if period == "yearly":
        return _add_months(next_date, steps * 12)
    return next_date


def _subs_days_left(next_date_iso: str) -> int | None:
    try:
        target = date.fromisoformat(next_date_iso)
    except ValueError:
        return None
    return (target - date.today()).days


