def _build_csv_bytes(headers: list[str], rows: list[list[object]]) -> bytes:
    buf = io.StringIO()
    writer = csv.writer(buf)
    writer.writerow(headers)
    writer.writerows(rows)
    return buf.getvalue().encode("utf-8")


async def _estimate_drive_eta_minutes(
    *,
    origin_lat: float,
    origin_lon: float,
    dest_lat: float,
    dest_lon: float,
) -> int | None:
    url = (
        "https://router.project-osrm.org/route/v1/driving/"
        f"{origin_lon:.6f},{origin_lat:.6f};{dest_lon:.6f},{dest_lat:.6f}"
    )
    payload = await request_json(
        service="osrm",
        method="GET",
        url=url,
        params={"overview": "false", "alternatives": "false", "steps": "false"},
        retries=1,
        timeout=12,
    )
    routes = payload.get("routes") or []
    if not routes:
        return None
    duration_sec = routes[0].get("duration")
    if duration_sec is None:
        return None
    return max(1, round(float(duration_sec) / 60))


def _digest_markup(
    digest_id: str,
    expanded: bool,
    *,
    lang: str,
    workout_id: int | None = None,
) -> InlineKeyboardMarkup:
    rows: list[list[InlineKeyboardButton]] = []
    if expanded:
        rows.append([InlineKeyboardButton(text=t(lang, "digest_less"), callback_data=f"digest:less:{digest_id}")])
    else:
        rows.append([InlineKeyboardButton(text=t(lang, "digest_more"), callback_data=f"digest:more:{digest_id}")])

    if workout_id is not None and workout_id > 0:
        rows.append(
            [
                InlineKeyboardButton(
                    text=t(lang, "digest_open_workout"),
                    callback_data=f"fit:show:{workout_id}",
                )
            ]
        )
    return InlineKeyboardMarkup(inline_keyboard=rows)


def _todo_trim(text: str, limit: int = 28) -> str:
    clean = " ".join((text or "").split())
