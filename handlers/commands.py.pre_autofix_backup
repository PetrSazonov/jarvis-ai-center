            parse_mode=render.compact.parse_mode,
            disable_web_page_preview=True,
            reply_markup=_digest_markup(
                digest_id,
                expanded=prefer_expanded,
                lang=lang,
                workout_id=render.workout_id,
            ),
        )
        ctx.logger.info(
            "event=command_done name=digest request_id=%s user_id=%s duration_ms=%d",
            rid,
            uid,
            int((perf_counter() - started) * 1000),
        )

    @router.callback_query(F.data.startswith("digest:"))
    async def digest_toggle_callback(callback: CallbackQuery) -> None:
        user_id = callback.from_user.id if callback.from_user else 0
        _runtime_settings, _profile, lang = _resolve_user_runtime_settings(ctx, user_id)
        raw = callback.data or ""
        parts = raw.split(":")
        if len(parts) != 3:
            await callback.answer(t(lang, "digest_bad_format"), show_alert=False)
            return

        _, action, digest_id = parts
        if action not in {"more", "less"}:
            await callback.answer(t(lang, "digest_unknown_action"), show_alert=False)
            return

        row = get_cache_value(_digest_cache_key(digest_id))
        if not row or not row[0]:
            await callback.answer(t(lang, "digest_expired"), show_alert=False)
            return

        try:
            payload = json.loads(row[0])
        except json.JSONDecodeError:
            await callback.answer(t(lang, "digest_bad_data"), show_alert=False)
            return

        text = payload.get("expanded") if action == "more" else payload.get("compact")
        parse_mode = payload.get("parse_mode") or None
        workout_id = payload.get("workout_id")
        if not isinstance(workout_id, int):
            workout_id = None
        if not text:
            await callback.answer(t(lang, "digest_no_data"), show_alert=False)
            return

        if callback.message:
            try:
                await callback.message.edit_text(
                    text=text,
                    parse_mode=parse_mode,
                    disable_web_page_preview=True,
                    reply_markup=_digest_markup(
                        digest_id,
                        expanded=(action == "more"),
                        lang=lang,
                        workout_id=workout_id,
                    ),
                )
            except Exception:
                ctx.logger.debug("event=digest_toggle_edit_failed digest_id=%s action=%s", digest_id, action)

        save_ui_event(
            event_type="digest_view",
            action=action,
            user_id=callback.from_user.id if callback.from_user else None,
            chat_id=callback.message.chat.id if callback.message else None,
            message_id=callback.message.message_id if callback.message else None,
            digest_id=digest_id,
            created_at=datetime.now().isoformat(timespec="seconds"),
        )
        await callback.answer(t(lang, "done_short"), show_alert=False)
    def _status_icon(ok: bool) -> str:
        return "\U0001F7E2" if ok else "\U0001F534"

    def _updated_line_compact(lang: str, *, value: datetime | None = None) -> str:
        dt = value or datetime.now()
        if lang == "ru":
            return f"\u041E\u0431\u043D\u043E\u0432\u043B\u0435\u043D\u043E: {dt:%d.%m %H:%M}"
        return f"Updated: {dt:%d.%m %H:%M}"

    def _service_line(name: str, ok: bool, note: str) -> str:
        return f"{_status_icon(ok)} {name}: {html_escape(note)}"

    @router.message(Command("status"))
    async def status_command(message: types.Message) -> None:
        rid = _request_id()
        uid = message.from_user.id if message.from_user else 0
        started = perf_counter()
        ctx.logger.info("event=command name=status request_id=%s user_id=%s", rid, uid)

        ollama_res, coingecko_res, cbr_res = await asyncio.gather(
            healthcheck_json(
                service="ollama",
                method="GET",
                url=_ollama_tags_url(ctx.settings.ollama_api_url),
            ),
            healthcheck_json(
                service="coingecko",
                method="GET",
                url="https://api.coingecko.com/api/v3/ping",
            ),
            healthcheck_json(
                service="cbr",
                method="GET",
                url="https://www.cbr-xml-daily.ru/daily_json.js",
            ),
        )
        ollama_ok, ollama_note = ollama_res
        coingecko_ok, coingecko_note = coingecko_res
        cbr_ok, cbr_note = cbr_res
        db_ok, db_note = ping_db()

        if ollama_ok:
            _clear_last_error(CACHE_KEY_LAST_ERROR_OLLAMA)
        else:
            _set_last_error(CACHE_KEY_LAST_ERROR_OLLAMA, kind=ollama_note, status=None)
        if coingecko_ok:
            _clear_last_error(CACHE_KEY_LAST_ERROR_COINGECKO)
        else:
            _set_last_error(CACHE_KEY_LAST_ERROR_COINGECKO, kind=coingecko_note, status=None)
        if cbr_ok:
            _clear_last_error(CACHE_KEY_LAST_ERROR_CBR)
        else:
            _set_last_error(CACHE_KEY_LAST_ERROR_CBR, kind=cbr_note, status=None)

        core_ok = all([ollama_ok, coingecko_ok, cbr_ok, db_ok])
        lang = ctx.settings.default_lang
        lines = [t(lang, "status_title"), ""]
        lines.append(f"{t(lang, 'status_core_label')}: {_status_icon(core_ok)} {'OK' if core_ok else 'FAIL'}")
        lines.append("")
        lines.append(_service_line("Ollama", ollama_ok, ollama_note))
        lines.append(_service_line("CoinGecko", coingecko_ok, coingecko_note))
        lines.append(_service_line("CBR FX", cbr_ok, cbr_note))
        lines.append(_service_line("DB", db_ok, db_note))
        lines.append("")
        lines.append(_updated_line_compact(lang))
        await message.reply("\n".join(lines), parse_mode="HTML")

        ctx.logger.info(
            "event=command_done name=status request_id=%s user_id=%s duration_ms=%d",
            rid,
            uid,
            int((perf_counter() - started) * 1000),
        )

    return router











