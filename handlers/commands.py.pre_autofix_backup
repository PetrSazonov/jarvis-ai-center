def _request_id() -> str:
    return uuid4().hex[:12]


def _start_seen_key(user_id: int) -> str:
    return f"user:start_seen:{user_id}"


def _has_seen_start(user_id: int) -> bool:
    row = get_cache_value(_start_seen_key(user_id))
    return bool(row and row[0] == "1")


def _mark_start_seen(user_id: int) -> None:
    set_cache_value(_start_seen_key(user_id), "1", datetime.now().isoformat(timespec="seconds"))


