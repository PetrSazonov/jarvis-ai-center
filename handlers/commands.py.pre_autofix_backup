async def _build_today_payload(
    ctx: AppContext,
    user_id: int,
    lang: str,
    *,
    runtime_settings=None,
    profile: dict[str, object] | None = None,
    mission_mode: bool = False,
    day_mode: str | None = None,
) -> tuple[str, InlineKeyboardMarkup | None]:
    settings_obj = runtime_settings or ctx.settings
    profile_data = profile or {}
    base_day_mode = str(day_mode or profile_data.get("day_mode") or "workday")
    autopilot_enabled = bool(profile_data.get("energy_autopilot", True))
    now_hour = datetime.now().hour

    checkin_row = daily_checkin_get(user_id=user_id, check_date=date.today().isoformat()) if user_id > 0 else None
    energy = int(checkin_row[2]) if checkin_row and checkin_row[2] is not None else None

    weather_summary = ""
    weather_line = None
    cached, _cached_ts = _cache_get_json_with_ts(CACHE_KEY_WEATHER)
    if cached and cached.get("summary"):
        weather_summary = str(cached.get("summary"))
        weather_line = f"{weather_emoji(weather_summary)} {weather_summary}"
    else:
        try:
            weather_summary = await asyncio.wait_for(
                fetch_weather_summary(settings_obj.weather_city, lang),
                timeout=4.0,
            )
            _cache_set_json(CACHE_KEY_WEATHER, {"summary": weather_summary, "city": settings_obj.weather_city})
            weather_line = f"{weather_emoji(weather_summary)} {weather_summary}"
        except (ExternalAPIError, asyncio.TimeoutError):
            weather_line = None

