def _parse_rule_when_then(text: str) -> tuple[str, str] | None:
    m = re.match(r"^/rule\s+add\s+if\s+(.+?)\s+then\s+(.+)$", (text or "").strip(), flags=re.IGNORECASE)
    if not m:
        return None
    condition_expr = m.group(1).strip()
    action_expr = m.group(2).strip()
    if not condition_expr or not action_expr:
        return None
    return condition_expr, action_expr


def _eval_condition_atom(atom: str, *, energy: int | None, weather_text: str, hour: int, mode: str) -> bool:
    part = atom.strip().lower().replace(" ", "")
    if not part:
        return False

    m_num = re.match(r"^(energy|hour)(<=|>=|=|<|>)(-?\d+)$", part)
    if m_num:
        field, op, raw = m_num.groups()
        left = energy if field == "energy" else hour
        if left is None:
            return False
        right = int(raw)
        if op == "<":
            return left < right
        if op == "<=":
            return left <= right
        if op == ">":
            return left > right
        if op == ">=":
            return left >= right
        return left == right

