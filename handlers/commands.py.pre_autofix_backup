        _runtime_settings, _profile, lang = _resolve_user_runtime_settings(ctx, user_id)
        if user_id <= 0:
            await message.reply(t(lang, "error_generic"))
            return
        parts = (message.text or "").strip().split(maxsplit=1)
        if len(parts) < 2 or not parts[1].strip():
            await message.reply(t(lang, "forget_help"))
            return
        key = " ".join(parts[1].strip().split()).lower()
        ok = memory_delete(user_id=user_id, key=key)
        msg_key = "forget_done" if ok else "forget_not_found"
        await message.reply(t(lang, msg_key, key=html_escape(key)), parse_mode="HTML")

