    async def _cancel_focus(user_id: int, *, status: str) -> bool:
        data = focus_tasks.pop(user_id, None)
        if not data:
            return False
        focus_id, task = data
        task.cancel()
        try:
            await task
        except asyncio.CancelledError:
            pass
        focus_session_finish(
            user_id=user_id,
            focus_id=focus_id,
            finished_at=datetime.now().isoformat(timespec="seconds"),
            status=status,
        )
        return True

