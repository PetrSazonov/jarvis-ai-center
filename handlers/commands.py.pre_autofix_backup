def _radar_rule_label(metric: str, operator: str, threshold: float | None, due_days: int | None, lang: str) -> str:
    if metric == "subs_due":
        days = int(due_days or 3)
        return f"subs_due <= {days}d"
    value = f"{threshold:.2f}" if threshold is not None else "n/a"
    return f"{metric} {operator} {value}"


def _cmp_threshold(value: float, operator: str, threshold: float) -> bool:
    if operator == "<=":
        return value <= threshold
    return value >= threshold


def _is_crisis_active(profile: dict[str, object]) -> tuple[bool, str | None]:
    crisis_until_raw = str(profile.get("crisis_until") or "").strip()
    if not crisis_until_raw:
        return False, None
    dt = _parse_iso_dt(crisis_until_raw)
    if dt is None:
        return False, None
    if datetime.now() < dt:
        return True, crisis_until_raw
    return False, crisis_until_raw


def _parse_decision_log_payload(payload: str) -> tuple[str, str, str]:
    chunks = [x.strip() for x in payload.split("|")]
    if not chunks or not chunks[0]:
        raise ValueError("empty")
    decision_text = chunks[0]
    hypothesis = chunks[1] if len(chunks) > 1 and chunks[1] else ""
    expected = chunks[2] if len(chunks) > 2 and chunks[2] else ""
    return decision_text, hypothesis, expected


