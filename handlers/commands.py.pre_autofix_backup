async def _safe_edit_todo_message(callback: CallbackQuery, *, text: str, rows) -> None:
    if not callback.message:
        return
    try:
        await callback.message.edit_text(text, reply_markup=_todo_markup(rows))
    except Exception:
        # Message may be unchanged or not editable anymore; fall back to a reply.
        await callback.message.reply(text, reply_markup=_todo_markup(rows))


async def _fitness_status(ctx: AppContext) -> tuple[bool, str]:
    if not ctx.settings.fitness_vault_chat_id or not ctx.settings.fitness_admin_user_id:
        workouts = fitness_workouts_count()
        if workouts > 0:
            return True, "text-only"
        return True, "ready"
    try:
        await ctx.bot.get_chat(ctx.settings.fitness_vault_chat_id)
        return True, "ok"
    except Exception as exc:
        return False, exc.__class__.__name__


