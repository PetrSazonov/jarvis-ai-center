    @router.message(Command("weather"))
    async def weather_command(message: types.Message) -> None:
        rid = _request_id()
        uid = message.from_user.id if message.from_user else 0
        runtime_settings, _profile, lang = _resolve_user_runtime_settings(ctx, uid)
        started = perf_counter()
        ctx.logger.info("event=command name=weather request_id=%s user_id=%s", rid, uid)

        cached, cached_ts = _cache_get_json_with_ts(CACHE_KEY_WEATHER)
        if cached and _is_cache_fast_usable(cached_ts) and cached.get("summary"):
            summary = str(cached.get("summary"))
            suffix = _cache_suffix(lang, cached_ts)
            updated_dt = _parse_iso_dt(cached_ts)
            await message.reply(
                f"{t(lang, 'screen_weather_title')}\n\n"
                f"{weather_emoji(summary)} {summary}{suffix}\n\n"
                f"{_updated_line(lang, value=updated_dt)}"
            )
            ctx.logger.info(
                "event=command_done name=weather request_id=%s user_id=%s duration_ms=%d source=cache_fast",
                rid,
                uid,
                int((perf_counter() - started) * 1000),
            )
            return

        try:
            summary = await asyncio.wait_for(
                fetch_weather_summary(runtime_settings.weather_city, lang),
                timeout=6.5,
            )
            _clear_last_error(CACHE_KEY_LAST_ERROR_WEATHER)
            _cache_set_json(CACHE_KEY_WEATHER, {"summary": summary, "city": runtime_settings.weather_city})
            await message.reply(
                f"{t(lang, 'screen_weather_title')}\n\n"
                f"{weather_emoji(summary)} {summary}\n\n"
                f"{_updated_line(lang)}"
            )
        except (ExternalAPIError, asyncio.TimeoutError) as exc:
            if isinstance(exc, ExternalAPIError):
                service = exc.service
                kind = exc.kind
                status = exc.status_code
            else:
                service = "weather"
                kind = "timeout"
                status = None
            ctx.logger.warning(
                "event=api_error request_id=%s user_id=%s service=%s kind=%s status=%s",
                rid,
                uid,
                service,
                kind,
                status,
            )
            _set_last_error(CACHE_KEY_LAST_ERROR_WEATHER, kind=kind, status=status)
            if cached and _is_cache_fast_usable(cached_ts) and cached.get("summary"):
                summary = str(cached.get("summary"))
                suffix = _cache_suffix(lang, cached_ts)
                updated_dt = _parse_iso_dt(cached_ts)
                await message.reply(
                    f"{t(lang, 'screen_weather_title')}\n\n"
                    f"{weather_emoji(summary)} {summary}{suffix}\n\n"
                    f"{_updated_line(lang, value=updated_dt)}"
                )
            else:
                await message.reply(t(lang, "weather_error"))
        ctx.logger.info(
            "event=command_done name=weather request_id=%s user_id=%s duration_ms=%d",
            rid,
            uid,
            int((perf_counter() - started) * 1000),
        )

