    @router.message(Command("life360"))
    async def life360_command(message: types.Message) -> None:
        user_id = message.from_user.id if message.from_user else 0
        lang = ctx.settings.default_lang
        if user_id <= 0:
            await message.reply(t(lang, "error_generic"))
            return
        since_iso = (datetime.now() - timedelta(days=7)).isoformat(timespec="seconds")
        done_count, open_count = todo_stats_recent(user_id=user_id, since_iso=since_iso)
        fit_total, _fit_rows = fitness_stats_recent(user_id=user_id, since_iso=since_iso)
        checkins = daily_checkin_recent(user_id=user_id, since_iso=since_iso, limit=7)
        energies = [int(r[3]) for r in checkins if r[3] is not None]
        avg_energy = (sum(energies) / len(energies)) if energies else 5.5
        focus_score = _life_zone_score(value=max(0.0, 10.0 - float(open_count)), max_value=10.0)
        zones = {
            "energy": _life_zone_score(value=avg_energy),
            "money": _life_zone_score(value=max(0.0, 8.0 - min(6.0, float(open_count) / 2)), max_value=10.0),
            "obligations": _life_zone_score(value=max(0.0, 10.0 - min(10.0, float(open_count / 2)))),
            "health": _life_zone_score(value=min(10.0, float(fit_total * 2))),
            "focus": focus_score,
            "goals": _life_zone_score(value=min(10.0, float(done_count / 2 + fit_total / 2))),
        }
        risk_index = int(round(sum(100 - v for v in zones.values()) / len(zones)))
