        user_id = message.from_user.id if message.from_user else 0
        runtime_settings, profile, lang = _resolve_user_runtime_settings(ctx, user_id)
        if user_id <= 0:
            await message.reply(t(lang, "error_generic"))
            return
        text = (message.text or "").strip()
        parts = text.split(maxsplit=3)
        if len(parts) == 1 or (len(parts) > 1 and parts[1].lower() == "status"):
            active, until_raw = _is_crisis_active(profile)
            if active:
                await message.reply(
                    f"Р В Р РӢР В РІРӮСҷР В Р РӢР РҺРЎСҹР В Р РӢР РҶРІРӮСӣРЎСӣР В Р’В Р В РЎвҖң Crisis mode: ON Р В Р’В Р вҖҷР’В Р В РЎСӣР РҶР вҖҡР’ВҳР В Р’В Р вҖҷР’В Р В Р РӢР РҶР вҖҡРЎСӣ {until_raw[:16]}.\nР В Р’В Р вҖҷР’В Р В РІРӮв„ўР вҖҷР’В Р В Р’В Р вҖҷР’В Р В РІРӮв„ўР вҖҷР’ВөР В Р’В Р вҖҷР’В Р В РІРӮв„ўР вҖҷР’В¶Р В Р’В Р вҖҷР’В Р В Р РӢР РҶР вҖҡР’ВҳР В Р’В Р вҖҷР’В Р В Р РӢР вҖҷР’Вҳ: Р В Р’В Р В Р вҖ№Р В Р вҖ Р В РІРӮСҷР РҺРІвҖһСһР В Р’В Р вҖҷР’В Р В Р РӢР РҶР вҖҡРЎСӣР В Р’В Р вҖҷР’В Р В РІРӮв„ўР вҖҷР’В»Р В Р’В Р В Р вҖ№Р В Р’В Р В РІРӮВ°Р В Р’В Р вҖҷР’В Р В Р РӢР РҶР вҖҡРЎСҡР В Р’В Р вҖҷР’В Р В Р РӢР РҶР вҖҡРЎСӣ Р В Р’В Р вҖҷР’В Р В Р РӢР РҶР вҖҡРЎСҡР В Р’В Р В Р вҖ№Р В Р’В Р РҶР вҖҡРЎв„ўР В Р’В Р вҖҷР’В Р В Р РӢР РҶР вҖҡР’ВҳР В Р’В Р В Р вҖ№Р В Р вҖ Р В РІРӮСҷР РҺРІвҖһСһР В Р’В Р вҖҷР’В Р В Р РӢР РҶР вҖҡР’ВҳР В Р’В Р В Р вҖ№Р В Р вҖ Р В РІРӮСҷР В Р вҖ№Р В Р’В Р вҖҷР’В Р В Р’В Р РҶР вҖҡР’ВҰР В Р’В Р В Р вҖ№Р В Р вҖ Р В РІРӮСҷР РҶРІРӮСӣРІРӮвҖңР В Р’В Р вҖҷР’В Р В РІРӮв„ўР вҖҷР’Вө Р В Р’В Р вҖҷР’В Р В РІРӮв„ўР вҖҷР’В·Р В Р’В Р вҖҷР’В Р В РІРӮв„ўР вҖҷР’В°Р В Р’В Р вҖҷР’В Р В РЎСӣР РҶР вҖҡР’ВҳР В Р’В Р вҖҷР’В Р В РІРӮв„ўР вҖҷР’В°Р В Р’В Р В Р вҖ№Р В Р вҖ Р В РІРӮСҷР В Р вҖ№Р В Р’В Р вҖҷР’В Р В Р РӢР РҶР вҖҡР’Вҳ."
