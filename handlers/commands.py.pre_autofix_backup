def _rule_matches(condition_expr: str, *, energy: int | None, weather_text: str, hour: int, mode: str) -> bool:
    atoms = [chunk.strip() for chunk in re.split(r"\band\b", condition_expr, flags=re.IGNORECASE) if chunk.strip()]
    if not atoms:
        return False
    for atom in atoms:
        if not _eval_condition_atom(atom, energy=energy, weather_text=weather_text, hour=hour, mode=mode):
            return False
    return True


def _parse_actions(action_expr: str) -> dict[str, str]:
    out: dict[str, str] = {}
    chunks = re.split(r"[,;]", action_expr)
    for chunk in chunks:
        part = chunk.strip()
        if "=" not in part:
            continue
        key, value = part.split("=", 1)
        k = key.strip().lower()
        v = value.strip().lower()
        if k and v:
            out[k] = v
    return out


