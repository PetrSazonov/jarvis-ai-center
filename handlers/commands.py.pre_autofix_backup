def _settings_text(profile: dict[str, object], runtime_settings, lang: str) -> str:
    city = str(profile.get("weather_city") or runtime_settings.weather_city or "-")
    tz = str(profile.get("timezone_name") or runtime_settings.timezone_name or "-")
    mode = str(profile.get("llm_mode") or "normal")
    digest_format = str(profile.get("digest_format") or "compact")
    style = _style_label(str(profile.get("response_style") or "balanced"), lang)
    density = _density_label(str(profile.get("response_density") or "auto"), lang)
    day_mode = _day_mode_label(str(profile.get("day_mode") or "workday"), lang)
    autopilot = "on" if bool(profile.get("energy_autopilot", True)) else "off"
    cognitive = "on" if bool(profile.get("cognitive_profile", True)) else "off"
    if lang == "en":
        return (
            "<b>Settings</b>\n"
            f"Language: {(profile.get('lang') or runtime_settings.default_lang).upper()}\n"
            f"Mode: {mode}\n"
            f"Timezone: {tz}\n"
